{
  "openapi": "3.1.1",
  "info": {
    "title": "backendSzM | v1",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "https://localhost:7231"
    },
    {
      "url": "http://localhost:5081"
    }
  ],
  "paths": {
    "/api/Auth/register": {
      "post": {
        "tags": [
          "Auth"
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/UserDataDTO"
              }
            },
            "text/json": {
              "schema": {
                "$ref": "#/components/schemas/UserDataDTO"
              }
            },
            "application/*+json": {
              "schema": {
                "$ref": "#/components/schemas/UserDataDTO"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "text/plain": {
                "schema": {
                  "$ref": "#/components/schemas/UserData"
                }
              },
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/UserData"
                }
              },
              "text/json": {
                "schema": {
                  "$ref": "#/components/schemas/UserData"
                }
              }
            }
          }
        }
      }
    },
    "/api/Auth/login": {
      "post": {
        "tags": [
          "Auth"
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/UserDataDTO"
              }
            },
            "text/json": {
              "schema": {
                "$ref": "#/components/schemas/UserDataDTO"
              }
            },
            "application/*+json": {
              "schema": {
                "$ref": "#/components/schemas/UserDataDTO"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "text/plain": {
                "schema": {
                  "type": "string"
                }
              },
              "application/json": {
                "schema": {
                  "type": "string"
                }
              },
              "text/json": {
                "schema": {
                  "type": "string"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "BannedUser": {
        "type": "object",
        "properties": {
          "banId": {
            "pattern": "^-?(?:0|[1-9]\\d*)$",
            "type": [
              "integer",
              "string"
            ],
            "format": "int32"
          },
          "isBanned": {
            "pattern": "^-?(?:0|[1-9]\\d*)(?:\\.\\d+)?(?:[eE][+-]?\\d+)?$",
            "type": [
              "number",
              "string"
            ],
            "format": "float"
          },
          "warnings": {
            "pattern": "^-?(?:0|[1-9]\\d*)$",
            "type": [
              "integer",
              "string"
            ],
            "format": "int32"
          },
          "userDatas": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/UserData"
            }
          }
        }
      },
      "Lobby": {
        "type": "object",
        "properties": {
          "id": {
            "pattern": "^-?(?:0|[1-9]\\d*)$",
            "type": [
              "integer",
              "string"
            ],
            "format": "int32"
          },
          "dm": {
            "type": "string"
          },
          "ttType": {
            "type": "string"
          },
          "location": {
            "type": "string"
          },
          "timeDate": {
            "type": "string",
            "format": "date-time"
          },
          "playerLimit": {
            "pattern": "^-?(?:0|[1-9]\\d*)$",
            "type": [
              "integer",
              "string"
            ],
            "format": "int32"
          },
          "lobbyCons": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/LobbyCon"
            }
          }
        }
      },
      "LobbyCon": {
        "type": "object",
        "properties": {
          "userId": {
            "pattern": "^-?(?:0|[1-9]\\d*)$",
            "type": [
              "integer",
              "string"
            ],
            "format": "int32"
          },
          "lobbyId": {
            "pattern": "^-?(?:0|[1-9]\\d*)$",
            "type": [
              "integer",
              "string"
            ],
            "format": "int32"
          },
          "userData": {
            "$ref": "#/components/schemas/UserData"
          },
          "lobby": {
            "$ref": "#/components/schemas/Lobby"
          }
        }
      },
      "UserAuth": {
        "type": "object",
        "properties": {
          "userAuthId": {
            "pattern": "^-?(?:0|[1-9]\\d*)$",
            "type": [
              "integer",
              "string"
            ],
            "format": "int32"
          },
          "isAdmin": {
            "pattern": "^-?(?:0|[1-9]\\d*)(?:\\.\\d+)?(?:[eE][+-]?\\d+)?$",
            "type": [
              "number",
              "string"
            ],
            "format": "float"
          },
          "userDatas": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/UserData"
            }
          }
        }
      },
      "UserData": {
        "type": "object",
        "properties": {
          "id": {
            "pattern": "^-?(?:0|[1-9]\\d*)$",
            "type": [
              "integer",
              "string"
            ],
            "format": "int32"
          },
          "name": {
            "type": "string"
          },
          "hash": {
            "type": "string"
          },
          "gmail": {
            "type": "string"
          },
          "rep": {
            "pattern": "^-?(?:0|[1-9]\\d*)$",
            "type": [
              "integer",
              "string"
            ],
            "format": "int32"
          },
          "lobbyCons": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/LobbyCon"
            }
          },
          "userAuth": {
            "$ref": "#/components/schemas/UserAuth"
          },
          "bannedUser": {
            "$ref": "#/components/schemas/BannedUser"
          }
        }
      },
      "UserDataDTO": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "gmail": {
            "type": "string"
          },
          "password": {
            "type": "string"
          }
        }
      }
    }
  },
  "tags": [
    {
      "name": "Auth"
    }
  ]
}