{
  "openapi": "3.1.1",
  "info": {
    "title": "backendSzM | v1",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "https://localhost:7231"
    },
    {
      "url": "http://localhost:5081"
    }
  ],
  "paths": {
    "/api/Auth/register": {
      "post": {
        "tags": [
          "Auth"
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/UserDataDTO"
              }
            },
            "text/json": {
              "schema": {
                "$ref": "#/components/schemas/UserDataDTO"
              }
            },
            "application/*+json": {
              "schema": {
                "$ref": "#/components/schemas/UserDataDTO"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/Auth/login": {
      "post": {
        "tags": [
          "Auth"
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/UserDataDTO"
              }
            },
            "text/json": {
              "schema": {
                "$ref": "#/components/schemas/UserDataDTO"
              }
            },
            "application/*+json": {
              "schema": {
                "$ref": "#/components/schemas/UserDataDTO"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/Auth/Change Role": {
      "patch": {
        "tags": [
          "Auth"
        ],
        "parameters": [
          {
            "name": "Id",
            "in": "query",
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/RoleDTO"
              }
            },
            "text/json": {
              "schema": {
                "$ref": "#/components/schemas/RoleDTO"
              }
            },
            "application/*+json": {
              "schema": {
                "$ref": "#/components/schemas/RoleDTO"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/Auth/Create Lobby": {
      "post": {
        "tags": [
          "Auth"
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/LobbyDTO"
              }
            },
            "text/json": {
              "schema": {
                "$ref": "#/components/schemas/LobbyDTO"
              }
            },
            "application/*+json": {
              "schema": {
                "$ref": "#/components/schemas/LobbyDTO"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/Auth/AddPlayer": {
      "post": {
        "tags": [
          "Auth"
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/JoinLobbyDTO"
              }
            },
            "text/json": {
              "schema": {
                "$ref": "#/components/schemas/JoinLobbyDTO"
              }
            },
            "application/*+json": {
              "schema": {
                "$ref": "#/components/schemas/JoinLobbyDTO"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/Auth/{Id}": {
      "delete": {
        "tags": [
          "Auth"
        ],
        "parameters": [
          {
            "name": "Id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/Auth/refresh": {
      "post": {
        "tags": [
          "Auth"
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/RefreshTokenReqDto"
              }
            },
            "text/json": {
              "schema": {
                "$ref": "#/components/schemas/RefreshTokenReqDto"
              }
            },
            "application/*+json": {
              "schema": {
                "$ref": "#/components/schemas/RefreshTokenReqDto"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "text/plain": {
                "schema": {
                  "$ref": "#/components/schemas/TokenResponseDto"
                }
              },
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TokenResponseDto"
                }
              },
              "text/json": {
                "schema": {
                  "$ref": "#/components/schemas/TokenResponseDto"
                }
              }
            }
          }
        }
      }
    },
    "/api/Auth": {
      "get": {
        "tags": [
          "Auth"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/Auth/admin-only": {
      "get": {
        "tags": [
          "Auth"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "JoinLobbyDTO": {
        "type": "object",
        "properties": {
          "lobbyId": {
            "type": "string",
            "format": "uuid"
          },
          "playerId": {
            "type": "string",
            "format": "uuid"
          }
        }
      },
      "LobbyDTO": {
        "type": "object",
        "properties": {
          "dm": {
            "type": "string"
          },
          "ttType": {
            "type": "string"
          },
          "location": {
            "type": "string"
          },
          "timeDate": {
            "type": "string",
            "format": "date-time"
          },
          "playerLimit": {
            "pattern": "^-?(?:0|[1-9]\\d*)$",
            "type": [
              "integer",
              "string"
            ],
            "format": "int32"
          },
          "image": {
            "type": "string"
          }
        }
      },
      "RefreshTokenReqDto": {
        "required": [
          "refreshToken"
        ],
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid"
          },
          "refreshToken": {
            "type": "string"
          }
        }
      },
      "RoleDTO": {
        "type": "object",
        "properties": {
          "changedUser": {
            "type": "string",
            "format": "uuid"
          },
          "roleChanger": {
            "type": "string",
            "format": "uuid"
          },
          "role": {
            "type": "string"
          }
        }
      },
      "TokenResponseDto": {
        "required": [
          "accesToken",
          "refreshToken"
        ],
        "type": "object",
        "properties": {
          "accesToken": {
            "type": "string"
          },
          "refreshToken": {
            "type": "string"
          }
        }
      },
      "UserDataDTO": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "gmail": {
            "type": "string"
          },
          "password": {
            "type": "string"
          }
        }
      }
    }
  },
  "tags": [
    {
      "name": "Auth"
    }
  ]
}