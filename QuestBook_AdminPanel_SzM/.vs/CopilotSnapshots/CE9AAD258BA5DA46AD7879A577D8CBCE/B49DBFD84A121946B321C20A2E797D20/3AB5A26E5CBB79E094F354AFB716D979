using Newtonsoft.Json.Linq;
using System;
using System.IdentityModel.Tokens.Jwt;
using System.Linq;
using System.Net.Http;
using System.Text;
using System.Threading.Tasks;
using System.Windows;

namespace QuestBook_AdminPanel_SzM
{
    public partial class LoginWindow : Window
    {
        private readonly string url = "https://c8bg6j6r-7231.euw.devtunnels.ms/";
        public string AccessToken { get; private set; }
        public bool IsAdminAuthenticated { get; private set; }

        public LoginWindow()
        {
            InitializeComponent();
            IsAdminAuthenticated = false;
        }

        private async void LoginButton_Click(object sender, RoutedEventArgs e)
        {
            ErrorMessage.Text = string.Empty;

            string username = UsernameTextBox.Text.Trim();
            string password = PasswordBox.Password;
            string gmail = GmailTextBox.Text.Trim();

            if (string.IsNullOrEmpty(username) || string.IsNullOrEmpty(password) || string.IsNullOrEmpty(gmail))
            {
                ErrorMessage.Text = "Kérlek töltsd ki az összes mezőt!";
                return;
            }

            await LoginAsync(username, password,gmail);
        }

        private async Task LoginAsync(string username, string password,string gmail)
        {
            try
            {
                System.Diagnostics.Debug.WriteLine($"Starting login to: {url}api/Auth/login");
                System.Diagnostics.Debug.WriteLine($"Username: {username}, Gmail: {gmail}");

                using (HttpClient client = new HttpClient())
                {
                    // Increase timeout for dev tunnels
                    client.Timeout = TimeSpan.FromSeconds(30);

                    var loginData = new
                    {
                        Name = username,
                        Gmail = gmail, 
                        Password = password

                    };

                    string jsonContent = Newtonsoft.Json.JsonConvert.SerializeObject(loginData);
                    System.Diagnostics.Debug.WriteLine($"Request JSON: {jsonContent}");

                    var content = new StringContent(jsonContent, Encoding.UTF8, "application/json");

                    HttpResponseMessage response = await client.PostAsync($"{url}api/Auth/login", content);
                    System.Diagnostics.Debug.WriteLine($"Response Status: {response.StatusCode}");

                    if (response.IsSuccessStatusCode)
                    {
                        string jsonResponse = await response.Content.ReadAsStringAsync();
                        System.Diagnostics.Debug.WriteLine($"Login response: {jsonResponse}");

                        JObject tokenData = JObject.Parse(jsonResponse);
                        AccessToken = tokenData["accesToken"]?.ToString();

                        if (!string.IsNullOrEmpty(AccessToken))
                        {
                            // TODO: Admin role check disabled for testing
                            // bool isAdmin = IsUserAdmin(AccessToken);

                            IsAdminAuthenticated = true;
                            DialogResult = true;
                            Close();
                        }
                        else
                        {
                            ErrorMessage.Text = "Nincs access token a válaszban!";
                        }
                    }
                    else
                    {
                        string errorContent = await response.Content.ReadAsStringAsync();
                        System.Diagnostics.Debug.WriteLine($"Error response: {errorContent}");

                        // Try to parse the error message from the response
                        string errorMessage = errorContent;
                        try
                        {
                            // If it's JSON with a message, extract it
                            if (errorContent.StartsWith("{"))
                            {
                                var errorJson = JObject.Parse(errorContent);
                                errorMessage = errorJson["message"]?.ToString() ?? errorContent;
                            }
                        }
                        catch { }

                        ErrorMessage.Text = $"Bejelentkezési hiba:\n{errorMessage}";
                        MessageBox.Show($"A bejelentkezés sikertelen!\n\nHibakód: {response.StatusCode}\nÜzenet: {errorMessage}", 
                                      "Bejelentkezési hiba", 
                                      MessageBoxButton.OK, 
                                      MessageBoxImage.Warning);
                    }
                }
            }
            catch (HttpRequestException httpEx)
            {
                System.Diagnostics.Debug.WriteLine($"HTTP Error: {httpEx}");
                ErrorMessage.Text = $"Hálózati hiba: {httpEx.Message}\n\nEllenőrizd, hogy a backend fut-e és a Dev Tunnel aktív-e!";
                MessageBox.Show($"Részletes hiba:\n{httpEx.ToString()}", "HTTP Hiba", MessageBoxButton.OK, MessageBoxImage.Error);
            }
            catch (TaskCanceledException timeoutEx)
            {
                System.Diagnostics.Debug.WriteLine($"Timeout Error: {timeoutEx}");
                ErrorMessage.Text = "Időtúllépés! A szerver nem válaszolt időben.";
                MessageBox.Show($"A kérés túl sokáig tartott. Ellenőrizd a backend állapotát!", "Időtúllépés", MessageBoxButton.OK, MessageBoxImage.Warning);
            }
            catch (Exception ex)
            {
                System.Diagnostics.Debug.WriteLine($"General Error: {ex}");
                ErrorMessage.Text = $"Hiba történt: {ex.Message}";
                MessageBox.Show($"Részletes hiba:\n{ex.ToString()}", "Hiba", MessageBoxButton.OK, MessageBoxImage.Error);
            }
        }

        private bool IsUserAdmin(string accessToken)
        {
            try
            {
                var handler = new JwtSecurityTokenHandler();
                var token = handler.ReadJwtToken(accessToken);

                // Debug: Log all claims to see what's in the token
                var allClaims = string.Join(", ", token.Claims.Select(c => $"{c.Type}={c.Value}"));
                System.Diagnostics.Debug.WriteLine($"Token claims: {allClaims}");

                // Try multiple possible role claim types
                var roleClaim = token.Claims.FirstOrDefault(c => 
                    c.Type == "http://schemas.microsoft.com/ws/2008/06/identity/claims/role" ||
                    c.Type == "role" ||
                    c.Type == "Role");

                if (roleClaim != null)
                {
                    System.Diagnostics.Debug.WriteLine($"Found role: {roleClaim.Value}");
                    return roleClaim.Value?.Equals("Admin", StringComparison.OrdinalIgnoreCase) == true;
                }
                else
                {
                    ErrorMessage.Text = "Nem található szerepkör információ a tokenben.";
                    System.Diagnostics.Debug.WriteLine("No role claim found in token");
                    return false;
                }
            }
            catch (Exception ex)
            {
                ErrorMessage.Text = $"Token feldolgozási hiba: {ex.Message}";
                System.Diagnostics.Debug.WriteLine($"Token parsing error: {ex}");
                return false;
            }
        }

        private void CancelButton_Click(object sender, RoutedEventArgs e)
        {
            DialogResult = false;
            Close();
        }
    }
}