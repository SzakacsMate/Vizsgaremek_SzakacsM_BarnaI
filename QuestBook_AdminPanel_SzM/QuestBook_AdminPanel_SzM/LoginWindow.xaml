<Window x:Class="QuestBook_AdminPanel_SzM.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:QuestBook_AdminPanel_SzM"
        mc:Ignorable="d"
        Title="Admin Panel - Bejelentkezes"
        Height="300"
        Width="400"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize">
    <Grid Margin="10,20,20,6">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="20"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="20"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="20"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="20"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="Admin Panel Bejelentkezes"
                   FontSize="20"
                   FontWeight="Bold"
                   HorizontalAlignment="Center"/>

        <TextBlock Grid.Row="2" Text="Felhasznalonev:" FontWeight="SemiBold"/>
        <TextBox Grid.Row="4"
                 x:Name="UsernameTextBox"
                 Height="30"
                 VerticalContentAlignment="Center"/>

        <TextBlock Grid.Row="6" Text="Jelszo:" FontWeight="SemiBold"/>
        <PasswordBox Grid.Row="8"
                     x:Name="PasswordBox"
                     Height="30"
                     VerticalContentAlignment="Center"/>

        <StackPanel Grid.Row="10"
                    Orientation="Horizontal"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Bottom"
                    Margin="0,10,0,0">
            <Button Content="Bejelentkezes"
                    Width="120"
                    Height="35"
                    Click="LoginButton_Click"
                    IsDefault="True"
                    Margin="0,0,10,0"/>
            <Button Content="Megse"
                    Width="120"
                    Height="35"
                    Click="CancelButton_Click"
                    IsCancel="True"/>
        </StackPanel>

        <TextBlock Grid.Row="10"
                   x:Name="ErrorMessage"
                   Foreground="Red"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Top"
                   TextWrapping="Wrap"
                   Margin="0,10,0,0"/>
    </Grid>
</Window>